# secrets
.env
*.env.local

# persistent data (bind-mounted into containers)
data/

# agent state machine runtime artifacts
agent/inbox/*
agent/running/*
agent/plan/*
agent/build/*
agent/test/*
agent/review/*
agent/done/*
agent/error/*
!agent/inbox/
!agent/running/
!agent/plan/
!agent/build/
!agent/test/
!agent/review/
!agent/done/
!agent/error/
!agent/**/.gitkeep
*.lock

# target repos (cloned or generated, not source of truth for this repo)
target-repos/*/node_modules/
target-repos/*/dist/
target-repos/*/.env
target-repos/*/agent/
target-repos/*/.git.local-backup-*/

agent/archive/
agent/comms/
agent/debug/
agent/jobs/

# execution error reports
errors/*.md
!errors/.gitkeep

# logs
*.log

# local usage and provider dumps
codex-*-usage.json
codex-cli-noninteractive.json
codex-plus-user-reports.json
hermesagent-wechat-positioning.json
openclaw-openai-provider.json

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# n8n workflow backups
n8n-workflows/*.bak
